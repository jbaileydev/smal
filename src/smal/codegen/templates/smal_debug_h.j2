}

/**
 * @brief Create an error debugging entry.
 * 
 * @param error_code The error code encountered.
 * @param detail Any details associated with the error code.
 * @return smal_debug_entry_t The created error debugging entry.
 */
static inline smal_debug_entry_t smal_debug_create_error(int32_t error_code, uint32_t detail)
{
    smal_debug_entry_t entry;

    entry.entry_type = SMAL_DEBUG_ENTRY_TYPE_ERROR;
    entry.timestamp_ms = smal_debug_get_timestamp_ms();
    entry.payload.error.error_code = error_code;
    entry.payload.error.detail = detail;

    return entry;
}

/**
 * @brief Create and push a state transition debugging entry to the ring buffer.
 * 
 * @param ring Reference to the ring buffer.
 * @param src_state The source state of the transition.
 * @param evt The triggering event that caused the transition.
 * @param tgt_state The target state of the transition.
 * @param status The current status of the state machine.
 * @return true If the entry was successfully created and pushed to the ring buffer.
 * @return false If the entry was not successfully created or pushed to the ring buffer.
 */
static inline bool smal_debug_log_transition(smal_debug_ring_t *ring, uint16_t src_state, uint16_t evt, uint16_t tgt_state, int16_t status)
{
    smal_debug_entry_t entry = smal_debug_create_transition(src_state, evt, tgt_state, status);
    return smal_debug_ring_push(ring, &entry);
}

/**
 * @brief Create and push a message debugging entry to the ring buffer.
 * 
 * @param ring Reference to the ring buffer.
 * @param entry_type The type of entry, either event or command.
 * @param identifier The identifier of the message.
 * @param data_len The length of the message data.
 * @param value The value of the message data.
 * @return true If the entry was successfully created and pushed to the ring buffer.
 * @return false If the entry was not successfully created or pushed to the ring buffer.
 */
static inline bool smal_debug_log_msg(smal_debug_ring_t *ring, uint32_t entry_type, uint16_t identifier, uint16_t data_len, uint32_t value)
{
    smal_debug_entry_t entry = smal_debug_create_msg(entry_type, identifier, data_len, value);
    return smal_debug_ring_push(ring, &entry);
}

